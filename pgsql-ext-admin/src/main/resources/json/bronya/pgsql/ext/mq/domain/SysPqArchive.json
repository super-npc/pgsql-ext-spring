{
  "type": "page",
  "body":
  [
    {
      "type": "crud",
      "syncLocation": false,
      "autoGenerateFilter":
      {
        "columnsNum": 5,
        "defaultCollapsed": true,
        "showBtnToolbar": true
      },
      "defaultCollapsed": true,
      "showIndex": false,
      "api":
      {
        "method": "post",
        "url": "/admin/base/amis/page",
        "data":
        {
          "&": "$$",
          "One2ManyReq.entity": "${One2ManyReq.entity}",
          "One2ManyReq.entityField": "${One2ManyReq.entityField}",
          "One2ManyReq.entityFieldVal": "${One2ManyReq.entityFieldVal}",
          "BindMiddleChild.entity": "${BindMiddleChild.entity}",
          "BindMiddleChild.selfField": "${BindMiddleChild.selfField}",
          "BindMiddleChild.selfFieldVal": "${BindMiddleChild.selfFieldVal}",
          "BindMiddleChild.joinField": "${BindMiddleChild.joinField}"
        },
        "headers":
        {
          "bean": "SysPqArchive"
        }
      },
      "quickSaveApi":
      {
        "method": "post",
        "url": "/admin/base/amis/quick-save-api",
        "headers":
        {
          "bean": "SysPqArchive"
        }
      },
      "headerToolbar":
      [
        "reload",
        {
          "type": "columns-toggler",
          "align": "right",
          "draggable": true,
          "icon": "fas fa-cog",
          "footerBtnSize": "sm"
        },
        "bulkActions"
      ],
      "footerToolbar":
      [
        "statistics",
        {
          "type": "pagination",
          "showPageInput": true,
          "layout": "perPage,pager,go"
        }
      ],
      "bulkActions":
      [
        {
          "type": "hidden",
          "label": "必须有兜底的按钮,不然会出现无法多选的情况"
        },
        {
          "actionType": "dialog",
          "level": "danger",
          "label": "重放",
          "hiddenOnHover": true,
          "type": "button",
          "icon": "/icon/btn/执行.svg",
          "dialog":
          {
            "size": "xs",
            "title": "执行'重放'?,选中:$ids",
            "closeOnEsc": true,
            "actions":
            [
              {
                "label": "确认",
                "actionType": "confirm",
                "type": "button",
                "level": "primary"
              }
            ],
            "body":
            {
              "type": "form",
              "mode": "horizontal",
              "api":
              {
                "headers":
                {
                  "clasz": "SysPqArchive",
                  "id": "$ids"
                },
                "method": "GET",
                "url": "/admin/pqmq/archive/replay"
              },
              "body":
              [
                
              ]
            }
          }
        }
      ],
      "itemActions":
      [
        {
          "label": "队列",
          "type": "button",
          "icon": "/icon/btn/关联.svg",
          "level": "enhance",
          "hiddenOnHover": true,
          "actionType": "dialog",
          "dialog":
          {
            "title": "pg归档.主键:「$SysPqArchive__msgId」 多对一关联 pg元数据",
            "body":
            {
              "type": "form",
              "initApi":
              {
                "method": "post",
                "url": "/admin/base/amis/bind-many2-one-view",
                "data":
                {
                  "id": "$SysPqArchive__msgId"
                },
                "headers":
                {
                  "bean": "SysPqArchive",
                  "bind-many2-one-class-field": "pgmqArchive"
                }
              },
              "body":
              [
                {
                  "label": "队列名称",
                  "name": "SysPqMeta__queueName",
                  "required": false,
                  "static": true,
                  "type": "input-text"
                },
                {
                  "label": "分区",
                  "name": "SysPqMeta__isPartitioned",
                  "static": true,
                  "type": "switch"
                },
                {
                  "label": "类型",
                  "name": "SysPqMeta__isUnlogged",
                  "static": true,
                  "type": "switch"
                },
                {
                  "label": "创建",
                  "name": "SysPqMeta__createdAt",
                  "static": true,
                  "type": "input-datetime"
                }
              ]
            }
          }
        },
        {
          "actionType": "dialog",
          "level": "danger",
          "label": "重放",
          "hiddenOnHover": true,
          "type": "button",
          "icon": "/icon/btn/执行.svg",
          "dialog":
          {
            "size": "xs",
            "title": "执行'重放'?,选中:$SysPqArchive__msgId",
            "closeOnEsc": true,
            "actions":
            [
              {
                "label": "确认",
                "actionType": "confirm",
                "type": "button",
                "level": "primary"
              }
            ],
            "body":
            {
              "type": "form",
              "mode": "horizontal",
              "api":
              {
                "headers":
                {
                  "clasz": "SysPqArchive",
                  "id": "$SysPqArchive__msgId"
                },
                "method": "GET",
                "url": "/admin/pqmq/archive/replay"
              },
              "body":
              [
                
              ]
            }
          }
        },
        {
          "label": "详情",
          "type": "button",
          "icon": "/icon/btn/详情.svg",
          "hiddenOnHover": true,
          "actionType": "dialog",
          "dialog":
          {
            "title": "查看数据「$SysPqArchive__msgId」",
            "size": "lg",
            "body":
            {
              "type": "form",
              "initApi":
              {
                "method": "post",
                "url": "/admin/base/amis/view",
                "data":
                {
                  "id": "$SysPqArchive__msgId"
                },
                "headers":
                {
                  "bean": "SysPqArchive"
                }
              },
              "body":
              [
                {
                  "label": "消息id",
                  "name": "SysPqArchive__msgId",
                  "required": false,
                  "static": true,
                  "type": "input-text"
                },
                {
                  "label": "读数",
                  "name": "SysPqArchive__readCt",
                  "static": true,
                  "type": "input-number"
                },
                {
                  "label": "入队",
                  "name": "SysPqArchive__enqueuedAt",
                  "static": true,
                  "type": "input-datetime"
                },
                {
                  "label": "最后读取",
                  "name": "SysPqArchive__lastReadAt",
                  "static": true,
                  "type": "input-datetime"
                },
                {
                  "label": "可见时间",
                  "name": "SysPqArchive__vt",
                  "static": true,
                  "type": "input-datetime"
                },
                {
                  "label": "消息主体",
                  "name": "SysPqArchive__message",
                  "static": true,
                  "type": "input-text"
                },
                {
                  "label": "元数据",
                  "name": "SysPqArchive__headers",
                  "static": true,
                  "type": "input-text"
                },
                {
                  "label": "归档时间",
                  "name": "SysPqArchive__archivedAt",
                  "static": true,
                  "type": "input-datetime"
                },
                {
                  "label": "队列",
                  "name": "SysPqArchive__pgmqArchive",
                  "required": true,
                  "static": true,
                  "type": "input-number"
                }
              ]
            }
          }
        }
      ],
      "itemBadge":
      {
        "text": "${badgeText}",
        "mode": "ribbon",
        "position": "top-left",
        "level": "${badgeLevel}",
        "visibleOn": "this.badgeText"
      },
      "rowClassNameExpr": "${badgeText == '未读' ? 'bg-green-50' : ''}",
      "columns":
      [
        {
          "copyable": true,
          "label": "消息id",
          "name": "SysPqArchive__msgId",
          "searchable":
          {
            "label": "消息id",
            "mode": "horizontal",
            "name": "SysPqArchive__msgId",
            "placeholder": "请输入消息id",
            "type": "input-number"
          },
          "sort": -100,
          "sortable": true,
          "static": true,
          "type": "static"
        },
        {
          "label": "读数",
          "name": "SysPqArchive__readCt",
          "sortable": true,
          "static": true,
          "type": "static"
        },
        {
          "label": "入队",
          "name": "SysPqArchive__enqueuedAt",
          "static": true,
          "type": "static-datetime",
          "valueFormat": "x",
          "width": "153px"
        },
        {
          "label": "最后读取",
          "name": "SysPqArchive__lastReadAt",
          "static": true,
          "type": "static-datetime",
          "valueFormat": "x",
          "width": "153px"
        },
        {
          "label": "可见时间",
          "name": "SysPqArchive__vt",
          "static": true,
          "type": "static-datetime",
          "valueFormat": "x",
          "width": "153px"
        },
        {
          "className": "",
          "jsonTheme": "twilight",
          "label": "消息主体",
          "levelExpand": 1,
          "mutable": false,
          "name": "SysPqArchive__message",
          "placeholder": "请稍等..",
          "source": "",
          "static": true,
          "type": "json"
        },
        {
          "className": "",
          "jsonTheme": "twilight",
          "label": "元数据",
          "levelExpand": 1,
          "mutable": false,
          "name": "SysPqArchive__headers",
          "placeholder": "请稍等..",
          "source": "",
          "static": true,
          "type": "json"
        },
        {
          "label": "归档时间",
          "name": "SysPqArchive__archivedAt",
          "static": true,
          "type": "static-datetime",
          "valueFormat": "x",
          "width": "153px"
        },
        {
          "label": "队列",
          "name": "SysPqArchive__pgmqArchive",
          "searchable":
          {
            "type": "picker",
            "name": "SysPqArchive__pgmqArchive",
            "joinValues": true,
            "disabled": false,
            "valueField": "msgId",
            "labelField": "SysPqMeta__queueName",
            "label": "队列",
            "source":
            {
              "method": "post",
              "url": "/admin/base/amis/page",
              "data":
              {
                "&": "$$"
              },
              "headers":
              {
                "bean": "SysPqMeta"
              }
            },
            "modalSize": "xl",
            "size": "xl",
            "embed": false,
            "multiple": false,
            "pickerSchema":
            {
              "type": "crud",
              "syncLocation": false,
              "autoGenerateFilter": true,
              "defaultCollapsed": true,
              "draggable": true,
              "headerToolbar":
              {
                
              },
              "footerToolbar":
              [
                "statistics",
                {
                  "type": "pagination",
                  "showPageInput": true,
                  "layout": "perPage,pager,go"
                }
              ],
              "columns":
              [
                {
                  "label": "队列名称",
                  "name": "SysPqMeta__queueName",
                  "searchable":
                  {
                    "label": "队列名称",
                    "mode": "horizontal",
                    "name": "SysPqMeta__queueName",
                    "placeholder": "请输入队列名称",
                    "type": "input-number"
                  },
                  "sort": -100,
                  "static": true,
                  "type": "static",
                  "width": "150px"
                },
                {
                  "itemSchema":
                  {
                    "color": "${color}",
                    "displayMode": "normal",
                    "label": "${label}",
                    "type": "tag"
                  },
                  "label": "分区",
                  "labelField": "label",
                  "map":
                  [
                    {
                      "color": "#800000",
                      "displayMode": "normal",
                      "label": "已分区",
                      "name": "true",
                      "type": "tag"
                    },
                    {
                      "color": "#FF7F50",
                      "displayMode": "normal",
                      "label": "未分区",
                      "name": "false",
                      "type": "tag"
                    }
                  ],
                  "name": "SysPqMeta__isPartitioned",
                  "searchable":
                  {
                    "label": "分区",
                    "mode": "horizontal",
                    "name": "SysPqMeta__isPartitioned",
                    "options":
                    [
                      {
                        "label": "开启",
                        "value": "true"
                      },
                      {
                        "label": "关闭",
                        "value": "false"
                      }
                    ],
                    "placeholder": "请输入分区",
                    "type": "select"
                  },
                  "static": true,
                  "type": "static-mapping",
                  "valueField": "name",
                  "width": "150px"
                },
                {
                  "itemSchema":
                  {
                    "color": "${color}",
                    "displayMode": "normal",
                    "label": "${label}",
                    "type": "tag"
                  },
                  "label": "类型",
                  "labelField": "label",
                  "map":
                  [
                    {
                      "color": "#D2691E",
                      "displayMode": "normal",
                      "label": "非持久化",
                      "name": "true",
                      "type": "tag"
                    },
                    {
                      "color": "#00008B",
                      "displayMode": "normal",
                      "label": "持久化",
                      "name": "false",
                      "type": "tag"
                    }
                  ],
                  "name": "SysPqMeta__isUnlogged",
                  "searchable":
                  {
                    "label": "类型",
                    "mode": "horizontal",
                    "name": "SysPqMeta__isUnlogged",
                    "options":
                    [
                      {
                        "label": "开启",
                        "value": "true"
                      },
                      {
                        "label": "关闭",
                        "value": "false"
                      }
                    ],
                    "placeholder": "请输入类型",
                    "type": "select"
                  },
                  "static": true,
                  "type": "static-mapping",
                  "valueField": "name",
                  "width": "150px"
                },
                {
                  "label": "创建",
                  "name": "SysPqMeta__createdAt",
                  "static": true,
                  "type": "static-datetime",
                  "valueFormat": "x",
                  "width": "153px"
                }
              ]
            }
          },
          "static": true,
          "type": "static",
          "visibleOn": "1 != 1"
        },
        {
          "label": "队列",
          "name": "SysPqArchive__pgmqArchiveDesc",
          "sort": 99,
          "static": true,
          "type": "static",
          "className": "text-info"
        }
      ]
    }
  ]
}